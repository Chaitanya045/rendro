{
  "name": "rendro",
  "version": "1.0.0",
  "description": "CLI to sync HTML docs to a Rendro server. Zero dependencies — just Node.js.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chaitanya045/rendro.git",
    "directory": "."
  },
  "homepage": "https://rendro.app",
  "keywords": ["docs", "documentation", "sync", "cli", "rendro"],
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "bin": {
    "rendro": "./bin/rendro.mjs"
  },
  "files": [
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "init-minio": "tsx scripts/init-minio.ts",
    "cli": "tsx cli/src/index.ts",
    "cli:build": "node scripts/build-cli.mjs",
    "deploy": "wrangler deploy --config wrangler.toml"
  },
  "dependencies": {},
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@better-auth/memory-adapter": "^1.6.23",
    "@convex-dev/better-auth": "^0.12.5",
    "@eslint/js": "^10.0.1",
    "@hono/node-server": "^2.0.6",
    "@libsql/client": "^0.17.4",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^3.2.0",
    "better-auth": "^1.6.23",
    "better-auth-cloudflare": "^0.3.0",
    "better-sqlite3": "^12.11.1",
    "convex": "^1.42.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "hono": "^4.4.0",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.107.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
