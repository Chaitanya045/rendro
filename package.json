{
  "name": "rendro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "init-minio": "tsx scripts/init-minio.ts",
    "cli": "tsx cli/src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@better-auth/memory-adapter": "^1.6.22",
    "@convex-dev/better-auth": "^0.12.5",
    "@hono/node-server": "^2.0.6",
    "better-auth": "^1.6.22",
    "convex": "^1.42.0",
    "dotenv": "^17.4.2",
    "hono": "^4.4.0",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^3.2.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
